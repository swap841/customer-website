l duration-300\" href=\"/auth\">Sign In</a><button class=\"md:hidden p-2 rounded-lg hover:bg-zinc-50 transition-colors\" aria-label=\"Toggle menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-5 h-5 text-zinc-700\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></div></div></nav><main class=\"pt-16 md:pt-16 min-h-screen\"><div class=\"max-w-4xl mx-auto p-4 md:p-6 pb-32\"><div class=\"flex items-center gap-3 mb-6\"><div class=\"bg-emerald-100 p-2 rounded-xl\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check w-6 h-6 text-emerald-600\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><div><h1 class=\"text-2xl font-bold text-gray-900\">Checkout</h1><p class=\"text-sm text-gray-500\">Secure &amp; encrypted payment</p></div></div><div class=\"bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-200\"><h2 class=\"font-bold text-lg mb-4 text-gray-800 flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-truck w-5 h-5 text-emerald-600\" aria-hidden=\"true\"><path d=\"M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2\"></path><path d=\"M15 18H9\"></path><path d=\"M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14\"></path><circle cx=\"17\" cy=\"18\" r=\"2\"></circle><circle cx=\"7\" cy=\"18\" r=\"2\"></circle></svg> Order Type</h2><div class=\"grid grid-cols-2 gap-4\"><div class=\"rounded-xl border-2 p-4 cursor-pointer transition-all border-emerald-500 bg-emerald-50 shadow-md\"><div class=\"flex items-center\"><div class=\"h-5 w-5 rounded-full border-2 flex items-center justify-center mr-3 border-emerald-500 bg-emerald-500\"><div class=\"h-2 w-2 rounded-full bg-white\"></div></div><div><h3 class=\"font-semibold flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-truck w-4 h-4\" aria-hidden=\"true\"><path d=\"M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2\"></path><path d=\"M15 18H9\"></path><path d=\"M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14\"></path><circle cx=\"17\" cy=\"18\" r=\"2\"></circle><circle cx=\"7\" cy=\"18\" r=\"2\"></circle></svg> Home Delivery</h3><p class=\"text-sm text-gray-600\">Get it delivered to your address</p><p class=\"text-sm font-medium mt-1\">Delivery: ₹25</p></div></div></div><div class=\"rounded-xl border-2 p-4 cursor-pointer transition-all border-gray-300 hover:bg-gray-50\"><div class=\"flex items-center\"><div class=\"h-5 w-5 rounded-full border-2 flex items-center justify-center mr-3 border-gray-400\"></div><div><h3 class=\"font-semibold flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-store w-4 h-4\" aria-hidden=\"true\"><path d=\"M15 21v-5a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v5\"></path><path d=\"M17.774 10.31a1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.451 0 1.12 1.12 0 0 0-1.548 0 2.5 2.5 0 0 1-3.452 0 1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.77-3.248l2.889-4.184A2 2 0 0 1 7 2h10a2 2 0 0 1 1.653.873l2.895 4.192a2.5 2.5 0 0 1-3.774 3.244\"></path><path d=\"M4 10.95V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8.05\"></path></svg> Store Pickup</h3><p class=\"text-sm text-gray-600\">Pick up from our store</p><p class=\"text-sm font-medium mt-1\">Free pickup</p></div></div></div></div></div><div class=\"bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-200\"><h2 class=\"font-bold text-lg mb-4 text-gray-800 flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-user w-5 h-5 text-emerald-600\" aria-hidden=\"true\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg> Customer Information</h2><div class=\"space-y-4\"><div class=\"rounded-xl border border-gray-300 p-3 bg-gray-50 focus-within:border-emerald-400 focus-within:ring-2 focus-within:ring-emerald-100 transition-all\"><label class=\"block text-sm font-medium text-gray-700 mb-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-user w-3.5 h-3.5 inline mr-1\" aria-hidden=\"true\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg> Full Name *</label><input class=\"w-full bg-transparent outline-none text-gray-800\" placeholder=\"Enter your full name\" required=\"\" value=\"\"/></div><div class=\"rounded-xl border border-gray-300 p-3 bg-gray-50 focus-within:border-emerald-400 focus-within:ring-2 focus-within:ring-emerald-100 transition-all\"><label class=\"block text-sm font-medium text-gray-700 mb-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone w-3.5 h-3.5 inline mr-1\" aria-hidden=\"true\"><path d=\"M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384\"></path></svg> Phone Number *</label><input class=\"w-full bg-transparent outline-none text-gray-800\" placeholder=\"Enter your phone number\" type=\"tel\" required=\"\" value=\"\"/></div><div class=\"rounded-xl border border-gray-300 p-3 bg-gray-50 focus-within:border-emerald-400 focus-within:ring-2 focus-within:ring-emerald-100 transition-all\"><label class=\"block text-sm font-medium text-gray-700 mb-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin w-3.5 h-3.5 inline mr-1\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg> Delivery Address *</label><textarea class=\"w-full bg-transparent outline-none text-gray-800 resize-none\" placeholder=\"Enter complete delivery address\" rows=\"3\" required=\"\"></textarea></div><div class=\"rounded-xl border border-gray-300 p-3 bg-gray-50\"><div class=\"flex justify-between items-center mb-1\"><label class=\"block text-sm font-medium text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-navigation w-3.5 h-3.5 inline mr-1\" aria-hidden=\"true\"><polygon points=\"3 11 22 2 13 21 11 13 3 11\"></polygon></svg> Delivery Location</label><button type=\"button\" class=\"text-xs bg-emerald-100 hover:bg-emerald-200 text-emerald-700 px-3 py-1.5 rounded-lg font-medium transition-colors flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin w-3 h-3\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg>Get Location</button></div><div><p class=\"text-gray-500 text-sm\">Location not detected yet</p></div></div></div></div><div class=\"bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-200\"><h2 class=\"font-bold text-lg mb-4 text-gray-800\">Bill Summary</h2><div class=\"space-y-3\"><div class=\"flex justify-between py-2\"><span class=\"text-gray-600\">Items total (<!-- -->0<!-- --> items)</span><span class=\"font-medium\">₹<!-- -->0</span></div><div class=\"flex justify-between py-2\"><span class=\"text-gray-600\">Delivery</span><span class=\"font-medium\">₹25</span></div><div class=\"flex justify-between py-2\"><span class=\"text-gray-600\">Tax</span><span class=\"font-medium\">₹<!-- -->0</span></div><div class=\"border-t pt-3 mt-2\"><div class=\"flex justify-between font-bold text-lg\"><span>Grand Total</span><span class=\"text-emerald-600\">₹<!-- -->25</span></div></div></div></div><div class=\"bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-200\"><h2 class=\"font-bold text-lg mb-4 text-gray-800 flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock w-5 h-5 text-emerald-600\" aria-hidden=\"true\"><path d=\"M12 6v6l4 2\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg> Delivery Time Slot</h2><div class=\"rounded-xl border border-gray-300 p-4 bg-gray-50\"><label class=\"block text-sm font-medium text-gray-700 mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock w-3.5 h-3.5 inline mr-1\" aria-hidden=\"true\"><path d=\"M12 6v6l4 2\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg>Preferred Delivery Time Slot</label><div class=\"grid grid-cols-3 gap-3\"><button type=\"button\" class=\"flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all duration-200 border-emerald-500 bg-emerald-50 shadow-md ring-2 ring-emerald-200\"><span class=\"text-2xl\">🌅</span><span class=\"text-sm font-semibold text-emerald-700\">Morning</span><span class=\"text-xs text-emerald-600\">8 AM – 12 PM</span></button><button type=\"button\" class=\"flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all duration-200 border-gray-200 bg-white hover:bg-gray-50 hover:border-gray-300\"><span class=\"text-2xl\">☀️</span><span class=\"text-sm font-semibold text-gray-800\">Afternoon</span><span class=\"text-xs text-gray-500\">12 PM – 5 PM</span></button><button type=\"button\" class=\"flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all duration-200 border-gray-200 bg-white hover:bg-gray-50 hover:border-gray-300\"><span class=\"text-2xl\">🌆</span><span class=\"text-sm font-semibold text-gray-800\">Evening</span><span class=\"text-xs text-gray-500\">5 PM – 9 PM</span></button></div></div></div><div class=\"bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-200\"><h2 class=\"font-bold text-lg mb-4 text-gray-800 flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-credit-card w-5 h-5 text-emerald-600\" aria-hidden=\"true\"><rect width=\"20\" height=\"14\" x=\"2\" y=\"5\" rx=\"2\"></rect><line x1=\"2\" x2=\"22\" y1=\"10\" y2=\"10\"></line></svg> Payment Method</h2><div class=\"space-y-3\"><div class=\"rounded-xl border-2 p-4 cursor-pointer transition-all border-emerald-500 bg-emerald-50 shadow-md\"><label class=\"flex items-center cursor-pointer\"><input type=\"radio\" class=\"h-5 w-5 text-emerald-600 accent-emerald-600\" checked=\"\"/><div class=\"ml-3\"><span class=\"text-gray-800 font-medium flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-banknote w-5 h-5 text-emerald-600\" aria-hidden=\"true\"><rect width=\"20\" height=\"12\" x=\"2\" y=\"6\" rx=\"2\"></rect><circle cx=\"12\" cy=\"12\" r=\"2\"></circle><path d=\"M6 12h.01M18 12h.01\"></path></svg> Cash on Delivery</span><p class=\"text-xs text-gray-500 mt-1\">Pay when you receive your order</p></div></label></div><div class=\"rounded-xl border-2 p-4 cursor-pointer transition-all border-gray-300 hover:bg-gray-50\"><label class=\"flex items-center cursor-pointer\"><input type=\"radio\" class=\"h-5 w-5 text-emerald-600 accent-emerald-600\"/><div class=\"ml-3\"><span class=\"text-gray-800 font-medium flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-credit-card w-5 h-5 text-emerald-600\" aria-hidden=\"true\"><rect width=\"20\" height=\"14\" x=\"2\" y=\"5\" rx=\"2\"></rect><line x1=\"2\" x2=\"22\" y1=\"10\" y2=\"10\"></line></svg> Pay Online (Razorpay)</span><p class=\"text-xs text-gray-500 mt-1\">UPI,