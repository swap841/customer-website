# Firebase Config — Must match your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=my-store-51b02.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=my-store-51b02
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=my-store-51b02.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=240390353694
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side only — required for COD orders via /api/orders/create)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=my-store-51b02
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@my-store-51b02.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ImgBB API Key (server-side only — used by /api/upload-photo proxy)
IMGBB_API_KEY=your_imgbb_api_key_here

# reCAPTCHA v3 Site Key for Firebase App Check
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Razorpay Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Firebase VAPID Key — get from Firebase Console → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here
